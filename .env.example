# RelayCLI environment example — copy to ".env" and fill in what you use.
# RelayCLI reads provider keys by their standard names, so these also work
# with any other tool that expects them. Never commit your real .env.

# --- Default model (optional; RELAYCLI_ prefix) ---
# LiteLLM model id. Examples:
#   gpt-4o-mini | claude-3-5-sonnet-latest | gemini/gemini-1.5-pro | ollama/llama3.1
RELAYCLI_MODEL=gpt-4o-mini

# SECURITY: the permission mode and the Ollama base URL are deliberately NOT
# read from a project-local .env — an untrusted repo must not be able to
# silently switch RelayCLI into full-auto or redirect model traffic. Set the
# mode per run with `relaycli --mode ...`, or globally (real environment /
# ~/.relaycli/config.toml). RELAYCLI_PERMISSION_MODE / OLLAMA_BASE_URL placed
# in this file are ignored on purpose.

# --- Provider API keys (set only the ones you use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
# OpenRouter (one key, many models). Open-source examples:
#   openrouter/qwen/qwen3-coder:free | openrouter/deepseek/deepseek-v4-flash
#   (:free variants cost nothing but share capacity — expect rate limits)
OPENROUTER_API_KEY=

# --- Relay pipeline (optional) ---
# Run requests through Planner → Coder → Reviewer with per-role models.
# Enable per-session with `relaycli --relay` or `/relay on`, or persistently:
# RELAYCLI_RELAY_ENABLED=true
# Cheap model for planning/review, strong model for coding (each falls back
# to the base model above when unset):
# RELAYCLI_PLANNER_MODEL=gpt-4o-mini
# RELAYCLI_CODER_MODEL=claude-3-5-sonnet-latest
# RELAYCLI_REVIEWER_MODEL=gpt-4o-mini
# Revision cycles allowed after a 'revise' verdict (0 = no retries; an
# unresolved 'revise' ends the run as review_exhausted):
# RELAYCLI_MAX_REVIEW_CYCLES=2
